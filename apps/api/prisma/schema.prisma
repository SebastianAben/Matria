generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled
}

enum AuditOutcome {
  success
  failure
  denied
}

enum EncounterStatus {
  draft
  active
  reviewing
  closed
  approved
  archived
}

enum ConsentMode {
  audio
  transcript
  ai
  media
  fhir_export
}

enum ConsentStatus {
  granted
  withdrawn
  declined
}

enum ClinicalFileKind {
  audio
  image
  document
  ultrasound
}

enum ObservationType {
  vitals
  labs
  symptoms
  history
  medications
  allergies
  gestational_age
}

enum ObservationVerificationStatus {
  unverified
  clinician_entered
  clinician_verified
  corrected
  rejected
}

enum RuleSeverity {
  info
  watch
  warning
  critical
}

enum RuleBlockingLevel {
  none
  soft
  ack_required
  hard
}

enum RuleResultStatus {
  active
  acknowledged
  resolved
  overridden
  superseded
}

enum RuleActionType {
  suggestion
  missing_question
  acknowledge
  review
  escalation_review
}

enum RuleEvaluationRunStatus {
  completed
  failed
}

enum AmbientSessionStatus {
  initialized
  consent_pending
  listening
  transcribing
  diarizing
  normalizing
  closed
  failed
}

enum TranscriptCorrectionStatus {
  raw
  auto_diarized
  clinician_corrected
  system_revised
}

enum SpeakerRoleGuess {
  clinician
  patient
  companion
  unknown
}

enum TranscriptClinicalCandidateType {
  symptom_mention
  danger_sign_mention
  medication_mention
  history_mention
  gestational_age_mention
  clinician_plan
  unresolved_question
}

enum AiToolCallStatus {
  pending
  succeeded
  failed
  validation_failed
}

enum AiArtifactType {
  summary_update
  highlight_cards
  suggestions
  missing_questions
  session_note_draft_sections
  anc_note_draft
  teleconsult_summary_draft
  referral_summary_draft
  fhir_export_draft_inputs
  medgemma_handoff_request
  requires_human_review
}

enum AiPatchOperation {
  create
  update
  replace
  archive
  no_change
}

enum AiValidationStatus {
  valid
  invalid
  stale
}

enum AiReviewStatus {
  draft
  review_required
  rejected
  stale
}

enum SynthesisTickStatus {
  pending
  running
  completed
  failed
  validation_failed
  stale
  skipped
}

enum HighlightType {
  risk
  missing_context
  contradiction
  uncertainty
  memory
  media_evidence
  follow_up
}

enum SuggestionPriority {
  low
  medium
  high
  urgent
}

enum SuggestionStatus {
  open
  done
  skipped
  needs_follow_up
  superseded
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String     @unique
  fullName     String
  passwordHash String
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  roles        UserRole[]
  sessions     Session[]
  auditLogs    AuditLog[]             @relation("AuditActor")
  patients     Patient[]              @relation("PatientCreator")
  encounters   Encounter[]            @relation("EncounterCreator")
  observations StructuredObservation[]
  sessionNotes SessionNote[]
  ruleAcknowledgements RuleResult[] @relation("RuleAcknowledgementActor")
  ambientSessions AmbientSessionState[] @relation("AmbientSessionCreator")
  transcriptCorrections TranscriptTurn[] @relation("TranscriptCorrectionActor")
  contextSnapshots ContextSnapshot[] @relation("ContextSnapshotCreator")
  synthesisTicks SynthesisTick[] @relation("SynthesisTickRequester")
  suggestionResults SuggestionResult[] @relation("SuggestionResultActor")
  patientMemoryFacts PatientMemoryFact[] @relation("PatientMemoryFactCreator")
  medicalEvidenceHandoffs MedicalEvidenceHandoff[] @relation("MedicalEvidenceHandoffRequester")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique
  description String
  createdAt   DateTime @default(now())

  roles       RolePermission[]
}

model UserRole {
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?      @db.Uuid
  action     String
  targetType String
  targetId   String?
  outcome    AuditOutcome
  requestId  String
  metadata   Json?
  createdAt  DateTime     @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
}

model Patient {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospitalNumber String   @unique
  fullName       String
  dateOfBirth    DateTime?
  phone          String?
  address        String?
  createdById    String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy User @relation("PatientCreator", fields: [createdById], references: [id])
  pregnancyEpisodes PregnancyEpisode[]
  encounters Encounter[]
  contextSnapshots ContextSnapshot[]
  patientMemoryFacts PatientMemoryFact[]
}

model PregnancyEpisode {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId           String   @db.Uuid
  label               String
  estimatedDueDate    DateTime?
  gestationalAgeWeeks Int?
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounters Encounter[]
  contextSnapshots ContextSnapshot[]
  patientMemoryFacts PatientMemoryFact[]

  @@index([patientId])
}

model Encounter {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId          String          @db.Uuid
  pregnancyEpisodeId String          @db.Uuid
  status             EncounterStatus @default(draft)
  visitType          String          @default("routine_anc")
  facilityName       String?
  createdById        String          @db.Uuid
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  pregnancyEpisode PregnancyEpisode @relation(fields: [pregnancyEpisodeId], references: [id], onDelete: Restrict)
  createdBy User @relation("EncounterCreator", fields: [createdById], references: [id])
  consentRecords ConsentRecord[]
  clinicalFiles ClinicalFile[]
  observations StructuredObservation[]
  sessionNote SessionNote?
  ruleEvaluationRuns RuleEvaluationRun[]
  ruleResults RuleResult[]
  ambientSessions AmbientSessionState[]
  contextSnapshots ContextSnapshot[]

  @@index([patientId])
  @@index([pregnancyEpisodeId])
}

model ConsentRecord {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId String        @db.Uuid
  mode        ConsentMode
  status      ConsentStatus
  note        String?
  actorId     String        @db.Uuid
  createdAt   DateTime      @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, mode])
}

model ClinicalFile {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId     String           @db.Uuid
  kind            ClinicalFileKind
  fileName        String
  mimeType        String
  sizeBytes       Int
  storageUri      String?
  storageProvider String           @default("local")
  storageKey      String?
  checksumSha256  String?
  metadata        Json?
  createdById     String           @db.Uuid
  createdAt       DateTime         @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  frameSamples MedicalEvidenceFrameSample[]
  handoffs MedicalEvidenceHandoffFile[]
  findings MedicalEvidenceFinding[]

  @@index([encounterId])
  @@index([storageKey])
  @@index([checksumSha256])
}

model StructuredObservation {
  id                 String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId        String                        @db.Uuid
  type               ObservationType
  value              Json
  verificationStatus ObservationVerificationStatus @default(clinician_entered)
  source             String                        @default("manual_entry")
  createdById        String                        @db.Uuid
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([encounterId, type])
}

model SessionNote {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId String   @unique @db.Uuid
  content     String   @default("")
  version     Int      @default(1)
  updatedById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  updatedBy User @relation(fields: [updatedById], references: [id])
}

model RuleEvaluationRun {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId    String                  @db.Uuid
  triggeredById  String?                 @db.Uuid
  status         RuleEvaluationRunStatus @default(completed)
  metadata       Json?
  createdAt      DateTime                @default(now())
  completedAt    DateTime?

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  results   RuleResult[]

  @@index([encounterId, createdAt])
}

model RuleResult {
  id                            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluationRunId               String?            @db.Uuid
  encounterId                   String             @db.Uuid
  ambientSessionId              String?            @db.Uuid
  ruleId                        String
  ruleVersion                   String
  severity                      RuleSeverity
  blockingLevel                 RuleBlockingLevel
  actionType                    RuleActionType
  evidence                      Json
  sourceReferences              Json
  confidence                    Float
  suggestedAction               String
  needsLocalGuidelineValidation Boolean            @default(false)
  thresholdDescription          String?
  status                        RuleResultStatus   @default(active)
  acknowledgementNote           String?
  acknowledgedAt                DateTime?
  acknowledgedById              String?            @db.Uuid
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @updatedAt

  evaluationRun  RuleEvaluationRun? @relation(fields: [evaluationRunId], references: [id], onDelete: SetNull)
  encounter      Encounter          @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  ambientSession AmbientSessionState? @relation(fields: [ambientSessionId], references: [id], onDelete: SetNull)
  acknowledgedBy User?              @relation("RuleAcknowledgementActor", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([encounterId, status])
  @@index([ruleId, ruleVersion])
}

model AmbientSessionState {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId    String               @db.Uuid
  status         AmbientSessionStatus @default(initialized)
  stateVersion   Int                  @default(1)
  provider       String               @default("mock")
  providerState  Json?
  startedAt      DateTime?
  stoppedAt      DateTime?
  failedAt       DateTime?
  failureReason  String?
  createdById    String               @db.Uuid
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  createdBy User @relation("AmbientSessionCreator", fields: [createdById], references: [id])
  audioSegments AudioSegment[]
  transcriptTurns TranscriptTurn[]
  transcriptClinicalCandidates TranscriptClinicalCandidate[]
  ruleResults RuleResult[]
  aiToolCalls AiToolCall[]
  contextSnapshots ContextSnapshot[]
  artifactRevisions AiArtifactRevision[]
  summaryRevisions SummaryRevision[]
  highlightCards HighlightCard[]
  suggestions Suggestion[]
  synthesisTicks SynthesisTick[]
  evidenceHandoffs MedicalEvidenceHandoff[]
  evidenceFindings MedicalEvidenceFinding[]
  frameSamples MedicalEvidenceFrameSample[]

  @@index([encounterId, status])
}

model AudioSegment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId String   @db.Uuid
  sequence         Int
  mimeType         String
  durationMs       Int?
  byteLength       Int?
  storageUri       String?
  transcriptText   String?
  providerStatus   String?
  createdAt        DateTime @default(now())

  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  transcriptTurns TranscriptTurn[]

  @@unique([ambientSessionId, sequence])
  @@index([ambientSessionId, createdAt])
}

model TranscriptTurn {
  id                      String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId        String                     @db.Uuid
  sourceAudioSegmentId    String?                    @db.Uuid
  speakerLabel            String
  speakerRoleGuess        SpeakerRoleGuess           @default(unknown)
  roleConfidence          Float?
  startTimeMs             Int
  endTimeMs               Int
  text                    String
  languageCode            String                     @default("en-US")
  sttConfidence           Float?
  diarizationConfidence   Float?
  correctionStatus        TranscriptCorrectionStatus @default(raw)
  correctedById           String?                    @db.Uuid
  correctedAt             DateTime?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  sourceAudioSegment AudioSegment? @relation(fields: [sourceAudioSegmentId], references: [id], onDelete: SetNull)
  correctedBy User? @relation("TranscriptCorrectionActor", fields: [correctedById], references: [id], onDelete: SetNull)
  clinicalCandidates TranscriptClinicalCandidate[]

  @@index([ambientSessionId, startTimeMs])
}

model TranscriptClinicalCandidate {
  id               String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId String                          @db.Uuid
  transcriptTurnId String?                         @db.Uuid
  candidateType    TranscriptClinicalCandidateType
  text             String
  value            Json?
  sourceReferences Json
  confidence       Float?
  status           String                          @default("unverified")
  createdAt        DateTime                        @default(now())

  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  transcriptTurn TranscriptTurn? @relation(fields: [transcriptTurnId], references: [id], onDelete: SetNull)

  @@index([ambientSessionId, candidateType])
}

model AiToolCall {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId  String?          @db.Uuid
  contextSnapshotId String?          @db.Uuid
  provider          String
  model             String
  toolName          String
  status            AiToolCallStatus @default(pending)
  requestMetadata   Json?
  responseMetadata  Json?
  errorMessage      String?
  latencyMs         Int?
  createdAt         DateTime         @default(now())
  completedAt       DateTime?

  ambientSession AmbientSessionState? @relation(fields: [ambientSessionId], references: [id], onDelete: SetNull)
  contextSnapshot ContextSnapshot? @relation(fields: [contextSnapshotId], references: [id], onDelete: SetNull)

  @@index([ambientSessionId, createdAt])
  @@index([contextSnapshotId])
  @@index([status])
}

model ContextSnapshot {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId          String   @db.Uuid
  pregnancyEpisodeId String   @db.Uuid
  encounterId        String   @db.Uuid
  ambientSessionId   String   @db.Uuid
  sessionStateVersion Int
  sessionNoteVersion Int
  payload            Json
  sourceManifest     Json
  createdById        String?  @db.Uuid
  createdAt          DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  pregnancyEpisode PregnancyEpisode @relation(fields: [pregnancyEpisodeId], references: [id], onDelete: Restrict)
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  createdBy User? @relation("ContextSnapshotCreator", fields: [createdById], references: [id], onDelete: SetNull)
  aiToolCalls AiToolCall[]
  artifactRevisions AiArtifactRevision[]
  synthesisTicks SynthesisTick[]
  evidenceHandoffs MedicalEvidenceHandoff[]

  @@index([ambientSessionId, createdAt])
  @@index([patientId, pregnancyEpisodeId])
  @@index([encounterId])
}

model AiArtifactRevision {
  id                         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId           String             @db.Uuid
  contextSnapshotId          String             @db.Uuid
  artifactType               AiArtifactType
  operation                  AiPatchOperation
  artifactKey                String?
  content                    Json
  sourceReferences           Json
  confidence                 Float?
  uncertaintyReasons         Json
  ruleResultReferences       Json
  memoryReferences           Json
  medGemmaReferences         Json
  clinicianActionRequired    Boolean            @default(true)
  validationStatus           AiValidationStatus @default(valid)
  reviewStatus               AiReviewStatus     @default(review_required)
  version                    Int                @default(1)
  supersedesId               String?            @db.Uuid
  createdAt                  DateTime           @default(now())

  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  contextSnapshot ContextSnapshot @relation(fields: [contextSnapshotId], references: [id], onDelete: Cascade)
  supersedes AiArtifactRevision? @relation("ArtifactSupersession", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy AiArtifactRevision[] @relation("ArtifactSupersession")
  summaryRevisions SummaryRevision[]
  highlightCards HighlightCard[]
  suggestions Suggestion[]
  evidenceHandoffs MedicalEvidenceHandoff[]

  @@index([ambientSessionId, artifactType, createdAt])
  @@index([contextSnapshotId])
  @@index([validationStatus, reviewStatus])
}

model SummaryRevision {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId   String   @db.Uuid
  artifactRevisionId String?  @db.Uuid
  content            String
  sections           Json?
  sourceReferences   Json
  confidence         Float?
  createdAt          DateTime @default(now())

  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  artifactRevision AiArtifactRevision? @relation(fields: [artifactRevisionId], references: [id], onDelete: SetNull)

  @@index([ambientSessionId, createdAt])
}

model HighlightCard {
  id                     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId       String       @db.Uuid
  artifactRevisionId     String?      @db.Uuid
  type                   HighlightType
  severity               RuleSeverity
  title                  String
  body                   String
  sourceReferences       Json
  confidence             Float
  requiresAcknowledgement Boolean     @default(false)
  status                 String       @default("active")
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  artifactRevision AiArtifactRevision? @relation(fields: [artifactRevisionId], references: [id], onDelete: SetNull)

  @@index([ambientSessionId, status])
  @@index([severity])
}

model Suggestion {
  id                      String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId        String             @db.Uuid
  artifactRevisionId      String?            @db.Uuid
  title                   String
  rationale               String
  priority                SuggestionPriority
  status                  SuggestionStatus   @default(open)
  sourceReferences        Json
  resultOptions           Json
  freeTextAllowed         Boolean            @default(true)
  clinicianActionRequired Boolean            @default(true)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  artifactRevision AiArtifactRevision? @relation(fields: [artifactRevisionId], references: [id], onDelete: SetNull)
  results SuggestionResult[]

  @@index([ambientSessionId, status])
  @@index([priority])
}

model SuggestionResult {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  suggestionId        String   @db.Uuid
  selectedOptionValue String?
  selectedOptionLabel String?
  freeTextNote        String?
  actorId             String   @db.Uuid
  contextImpact       Json?
  createdAt           DateTime @default(now())

  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  actor User @relation("SuggestionResultActor", fields: [actorId], references: [id])

  @@index([suggestionId, createdAt])
}

model PatientMemoryFact {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId          String   @db.Uuid
  pregnancyEpisodeId String   @db.Uuid
  content            String
  sourceType         String
  sourceId           String?
  provenance         Json
  embedding          Unsupported("vector")?
  status             String   @default("approved")
  createdById        String?  @db.Uuid
  createdAt          DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  pregnancyEpisode PregnancyEpisode @relation(fields: [pregnancyEpisodeId], references: [id], onDelete: Restrict)
  createdBy User? @relation("PatientMemoryFactCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([patientId, pregnancyEpisodeId, status])
}

model SynthesisTick {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId  String              @db.Uuid
  contextSnapshotId String?             @db.Uuid
  requestedById     String?             @db.Uuid
  status            SynthesisTickStatus @default(pending)
  triggerReason     String              @default("manual")
  clientRequestId   String?
  stateVersion      Int
  startedAt         DateTime?
  completedAt       DateTime?
  failureReason     String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  contextSnapshot ContextSnapshot? @relation(fields: [contextSnapshotId], references: [id], onDelete: SetNull)
  requestedBy User? @relation("SynthesisTickRequester", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([ambientSessionId, stateVersion, status])
  @@index([clientRequestId])
}

model MedicalEvidenceFrameSample {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId  String?  @db.Uuid
  clinicalFileId    String   @db.Uuid
  sourceTimestampMs Int?
  frameIndex        Int      @default(0)
  storageProvider   String   @default("local")
  storageKey        String?
  storageUri        String?
  checksumSha256    String?
  mimeType          String
  width             Int?
  height            Int?
  qualityMetadata   Json?
  processingStatus  String   @default("sampled")
  failureReason     String?
  createdAt         DateTime @default(now())

  ambientSession AmbientSessionState? @relation(fields: [ambientSessionId], references: [id], onDelete: SetNull)
  clinicalFile ClinicalFile @relation(fields: [clinicalFileId], references: [id], onDelete: Cascade)
  handoffs MedicalEvidenceHandoffFrameSample[]
  findings MedicalEvidenceFinding[]

  @@index([clinicalFileId, createdAt])
  @@index([ambientSessionId, createdAt])
  @@unique([clinicalFileId, frameIndex, sourceTimestampMs])
}

model MedicalEvidenceHandoff {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId      String   @db.Uuid
  contextSnapshotId     String?  @db.Uuid
  requestingArtifactId  String?  @db.Uuid
  taskType              String
  exactQuestion         String
  clinicalContext       Json
  expectedOutputSchema  Json?
  safetyInstructions    String
  provider              String   @default("mock")
  model                 String
  status                String   @default("pending")
  failureReason         String?
  requestedById         String?  @db.Uuid
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  completedAt           DateTime?

  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  contextSnapshot ContextSnapshot? @relation(fields: [contextSnapshotId], references: [id], onDelete: SetNull)
  requestingArtifact AiArtifactRevision? @relation(fields: [requestingArtifactId], references: [id], onDelete: SetNull)
  requestedBy User? @relation("MedicalEvidenceHandoffRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  clinicalFiles MedicalEvidenceHandoffFile[]
  frameSamples MedicalEvidenceHandoffFrameSample[]
  findings MedicalEvidenceFinding[]

  @@index([ambientSessionId, status])
  @@index([contextSnapshotId])
}

model MedicalEvidenceHandoffFile {
  handoffId      String @db.Uuid
  clinicalFileId String @db.Uuid

  handoff MedicalEvidenceHandoff @relation(fields: [handoffId], references: [id], onDelete: Cascade)
  clinicalFile ClinicalFile @relation(fields: [clinicalFileId], references: [id], onDelete: Cascade)

  @@id([handoffId, clinicalFileId])
}

model MedicalEvidenceHandoffFrameSample {
  handoffId     String @db.Uuid
  frameSampleId String @db.Uuid

  handoff MedicalEvidenceHandoff @relation(fields: [handoffId], references: [id], onDelete: Cascade)
  frameSample MedicalEvidenceFrameSample @relation(fields: [frameSampleId], references: [id], onDelete: Cascade)

  @@id([handoffId, frameSampleId])
}

model MedicalEvidenceFinding {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ambientSessionId        String   @db.Uuid
  handoffId               String?  @db.Uuid
  clinicalFileId          String?  @db.Uuid
  frameSampleId           String?  @db.Uuid
  provider                String
  model                   String
  taskType                String
  findings                Json
  extractedValues         Json
  frameReferences         Json
  sourceEvidence          Json
  confidence              Float
  uncertaintyReasons      Json
  qualityLimitations      Json
  clinicianReviewRequired Boolean  @default(true)
  reviewStatus            String   @default("review_required")
  createdAt               DateTime @default(now())

  ambientSession AmbientSessionState @relation(fields: [ambientSessionId], references: [id], onDelete: Cascade)
  handoff MedicalEvidenceHandoff? @relation(fields: [handoffId], references: [id], onDelete: SetNull)
  clinicalFile ClinicalFile? @relation(fields: [clinicalFileId], references: [id], onDelete: SetNull)
  frameSample MedicalEvidenceFrameSample? @relation(fields: [frameSampleId], references: [id], onDelete: SetNull)

  @@index([ambientSessionId, createdAt])
  @@index([handoffId])
  @@index([clinicalFileId])
}
